# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Build output — shouldn't be tracked, and ends up containing a compiled copy
# of application.properties (with real API keys) every time you build.
target/

# Real config with live API keys — only application.example.properties (the
# placeholder template) should be committed.
src/main/resources/application.properties
